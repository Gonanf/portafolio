---
import { Button } from "@workspace/ui/components/button"
import {
  GithubLogoIcon,
  YoutubeLogoIcon,
  LinkedinLogoIcon,
} from "@phosphor-icons/react"
---

<footer class="relative border-2 border-dotted bg-card py-10">
  <div class="container mx-auto flex justify-between">
    <p class="text-center text-base/10 text-secondary-foreground uppercase">
      Sigueme en mis redes sociales:
    </p>
    <div class="flex gap-2">
      <Button
        variant="ghost"
        className="group border-dotted border-transparent hover:border-2 hover:border-border"
        size="icon-lg"
        ><a href="https://github.com/Gonanf"
          ><GithubLogoIcon
            className="size-8 group-hover:fill-muted-foreground"
          /></a
        >
      </Button>
      <Button
        variant="ghost"
        className="group border-2 border-dotted border-transparent hover:border-border"
        size="icon-lg"
        ><a href="https://www.youtube.com/channel/UCllNy6G6V8WgzgXguloZYiw"
          ><YoutubeLogoIcon
            className="size-8 group-hover:fill-muted-foreground"
          /></a
        >
      </Button>
      <Button
        variant="ghost"
        className="group border-2 border-dotted border-transparent hover:border-border"
        size="icon-lg"
        ><a href="https://www.linkedin.com/in/gabriel-solotorevsky-35524431b"
          ><LinkedinLogoIcon
            className="size-8 transition-all group-hover:fill-muted-foreground"
          /></a
        >
      </Button>
    </div>
  </div>
  <p
    class="font-italic absolute right-2 bottom-0 text-xs font-thin text-foreground/20"
  >
    - PD: El prototipo fue hecho en una noche
  </p>
</footer>
